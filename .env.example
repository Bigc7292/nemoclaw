# ─────────────────────────────────────────────────────────────────────────────
#  CEO-Chief HQ — Environment Variables Template
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# Your Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your NVIDIA NIM API key (starts with nvapi-)
NVIDIA_API_KEY=nvapi-your_key_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Comma-separated Telegram chat IDs allowed to use the bot.
# Leave blank to allow ALL chats (not recommended for production).
# Get your chat ID by messaging @userinfobot on Telegram.
ALLOWED_CHAT_IDS=123456789

# NVIDIA NIM model to use for inference.
# Default: nvidia/llama-3.1-nemotron-70b-instruct
# Other options:
#   nvidia/nemotron-mini-4b-instruct        (faster, lighter)
#   nvidia/llama-3.3-nemotron-super-49b-v1  (powerful MoE)
#   meta/llama-3.1-70b-instruct             (Meta Llama)
#   mistralai/mixtral-8x22b-instruct-v0.1   (Mixtral)
MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# Max number of messages to keep in memory per chat session (default: 20).
# Higher = longer memory but more tokens used per request.
MAX_HISTORY=20

# Port for the health-check HTTP server.
# Railway and Render set this automatically — do not change unless self-hosting.
PORT=3000
